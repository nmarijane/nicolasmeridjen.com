[
  {
    "id": "nicolasmeridjen-blog-deploy",
    "execute-command": "/deploy/deploy.sh",
    "command-working-directory": "/root/repos/nicolasmeridjen.com",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    }
  }
]
